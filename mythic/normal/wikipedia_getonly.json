{
  "name": "wikipedia_getonly",
  "post": {
    "verb": "POST",
    "uris": [
      "/wiki"
    ],
    "client": {
      "headers": {
        "Host": "en.wikipedia.org",
        "Accept": "text/html,application/xhtml+xml,application/xml;"
      },
      "parameters": null,
      "message": {
        "location": "cookie",
        "name": "__session"
      },
      "transforms": [
        {
          "action": "base64url",
          "value": ""
        },
        {
          "action": "prepend",
          "value": "https://en.wikipedia.org/w/index.php?search="
        },
        {
          "action": "append",
          "value": "&title=Special%3ASearch&go=Go"
        }
      ]
    },
